# ── GoHighLevel ──────────────────────────────────────────────────────────────
GHL_API_KEY=
GHL_LOCATION_ID=

# IDs internos de los Custom Fields en GHL
# Obtener en: GHL Dashboard → Settings → Custom Fields → [campo] → ID
# NOTA: pais_residencia NO necesita ID — es un campo estándar de GHL (contact.country)
# NOTA: pais_venta NO se auto-llena — el consultor lo registra en sesión 1
GHL_FIELD_ID_PROMOCION=
GHL_FIELD_ID_NIVEL=
GHL_FIELD_ID_BITACORA_URL=

# ── Google Drive ──────────────────────────────────────────────────────────────
# ID de la carpeta raíz "BITACORAS" en Google Drive
# Obtener de la URL: drive.google.com/drive/folders/[ESTE_ID]
BITACORAS_ROOT_ID=

# Ruta completa al JSON de credenciales del Service Account
# Ver: references/configuracion.md → "Setup Google Cloud"
GOOGLE_CREDENTIALS_PATH=
